<launch>
    <arg name="joy_dev" default="/dev/input/js0" />
    <arg name="config_filepath" default="$(find-pkg-share wos_bringup)/config/xbox.yaml" />
    <arg name="joy_topic" default="joy" />

    <node pkg="joy" exec="joy_node" name="joy_node">
        <param name="dev" value="$(var joy_dev)" />
        <param name="deadzone" value="0.2" />
        <param name="autorepeat_rate" value="20.0" />
        <remap from="joy" to="$(var joy_topic)" />
    </node>

    <node pkg="teleop_twist_joy" exec="teleop_node" name="teleop_twist_joy">
        <param from="$(var config_filepath)" />
        <remap from="joy" to="$(var joy_topic)" />
    </node>
</launch>
